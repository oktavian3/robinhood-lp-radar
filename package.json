{
  "name": "robinhood-lp-live-build",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "verify:sources": "tsx scripts/verify-data-sources.ts",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "health": "curl -s http://localhost:7474/health | python3 -m json.tool",
    "pools": "curl -s http://localhost:7474/pools | python3 -m json.tool",
    "dashboard": "cd dashboard && npm run dev",
    "db:status": "su - postgres -c \"psql -d lp_radar -c 'SELECT count(*) as pools FROM pools; SELECT count(*) as events FROM raw_events; SELECT count(*) as blocks FROM chain_blocks;'\""
  },
  "dependencies": {
    "bottleneck": "latest",
    "decimal.js": "^10.6.0",
    "dotenv": "latest",
    "grammy": "^1.45.1",
    "ioredis": "latest",
    "pg": "latest",
    "pino": "latest",
    "uuid": "^14.0.1",
    "viem": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "latest",
    "@types/uuid": "^10.0.0",
    "tsx": "latest",
    "typescript": "latest"
  }
}
