# Robinhood Chain
ROBINHOOD_RPC_URL=https://robinhood-mainnet.g.alchemy.com/v2/REPLACE_ME
ROBINHOOD_WSS_URL=wss://robinhood-mainnet.g.alchemy.com/v2/REPLACE_ME
ROBINHOOD_PUBLIC_RPC_URL=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_CHAIN_ID=4663

# CoinGecko Onchain
# Pro base:
COINGECKO_API_BASE=https://pro-api.coingecko.com/api/v3
COINGECKO_API_KEY=
COINGECKO_API_KEY_HEADER=x-cg-pro-api-key
COINGECKO_NETWORK_ID=robinhood

# DEX Screener — no key required
DEXSCREENER_API_BASE=https://api.dexscreener.com
DEXSCREENER_CHAIN_ID=robinhood

# Uniswap APIs
UNISWAP_API_KEY=
UNISWAP_TRADE_API_BASE=https://trade-api.gateway.uniswap.org/v1
UNISWAP_LIQUIDITY_API_BASE=https://liquidity.api.uniswap.org
UNISWAP_UNIVERSAL_ROUTER_VERSION=2.1.1

# Database
DATABASE_URL=postgresql://lp_radar:lp_radar@localhost:5432/lp_radar
REDIS_URL=redis://localhost:6379

# Application
LOG_LEVEL=info
APP_ENV=development
DATA_STALE_AFTER_SECONDS=90
FULL_SCREEN_INTERVAL_MINUTES=60
RANKING_INTERVAL_MINUTES=15
POSITION_CHECK_INTERVAL_MINUTES=5
